    "\"\"\"4. Write a function list_ops(nums) that:\n",
    "a) Removes duplicates while preserving the original order.\n",
    "b) Returns a new list with only elements at even indices, squared.\n",
    "c) Flattens the nested list into a single list using list comprehension.\n",
    "nums = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5] nested = [[1, 2, 3], [4, 5], [6, 7, 8,\n",
    "9]]\"\"\";"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 66,
   "id": "fe72d0a2-331f-47fe-8088-d473001264a2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Without Duplicates : [3, 1, 4, 5, 9, 2, 6]\n",
      "Even Index Squared : [9, 16, 25, 4, 25, 25]\n",
      "Flatten List : [1, 2, 3, 4, 5, 6, 7, 8, 9]\n"
     ]
    }
   ],
   "source": [
    "def list_ops(nums, nested):\n",
    "\n",
    "    # (a) Remove duplicates\n",
    "    unique = []\n",
    "\n",
    "    for num in nums:\n",
    "        if num not in unique:\n",
    "            unique.append(num)\n",
    "\n",
    "    print(\"Without Duplicates :\", unique)\n",
    "\n",
    "    # (b) Even index elements squared\n",
    "    square = [nums[i] ** 2 for i in range(0, len(nums), 2)]\n",
    "\n",
    "    print(\"Even Index Squared :\", square)\n",
    "\n",
    "    # (c) Flatten nested list\n",
    "    flat = [num for sub in nested for num in sub]\n",
    "\n",
    "    print(\"Flatten List :\", flat)\n",
    "\n",
    "\n",
    "nums = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]\n",
    "\n",
    "nested = [[1, 2, 3], [4, 5], [6, 7, 8, 9]]\n",
    "\n",
    "list_ops(nums, nested)"
   ]
  },
