    "# (a) power_all function\n",
    "\n",
    "def power_all(*nums, exp=2):\n",
    "\n",
    "    result = []\n",
    "\n",
    "    for num in nums:\n",
    "        result.append(num ** exp)\n",
    "\n",
    "    return result\n",
    "\n",
    "\n",
    "print(\"Power Values :\", power_all(2, 3, 4))\n",
    "print(\"Power Values :\", power_all(2, 3, 4, exp=3))\n",
    "\n",
    "\n",
    "# (b) profile function\n",
    "\n",
    "def profile(**info):\n",
    "\n",
    "    for key, value in info.items():\n",
    "        print(key, \":\", value)\n",
    "\n",
    "\n",
    "print(\"\\nProfile Details\")\n",
    "profile(name=\"Arjun\", age=20, city=\"Pune\")\n",
    "\n",
    "\n",
    "# (c) Sort by CGPA in descending order\n",
