   "source": [
    "\"\"\"1. Write a function analyze_sentence(sentence) that takes a sentence and returns a dictionary with\n",
    "word_count, char_count (excluding spaces), unique_words (case-insensitive), and\n",
    "most_frequent_word. Test it with:\n",
    "\"The quick brown fox jumps over the lazy dog the fox\"\n",
    "\"\"\";"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "a2ab87e0-b615-4d4d-b24e-da19cff34927",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "{'word_count': 11, 'char_count': 41, 'unique_words': 8, 'most_frequent_word': 'the'}\n"
     ]
    }
   ],
   "source": [
    "def analyze_sentence(sentence):\n",
    "\n",
    "    words = sentence.lower().split()\n",
    "\n",
    "    word_count = len(words)\n",
    "\n",
    "    char_count = len(sentence.replace(\" \", \"\"))\n",
    "\n",
    "    unique_words = len(set(words))\n",
    "\n",
    "    freq = {}\n",
    "\n",
    "    for word in words:\n",
    "        if word in freq:\n",
    "            freq[word] += 1\n",
    "        else:\n",
    "            freq[word] = 1\n",
    "\n",
    "    most_frequent_word = max(freq, key=freq.get)\n",
    "\n",
    "    result = {\n",
    "        \"word_count\": word_count,\n",
    "        \"char_count\": char_count,\n",
    "        \"unique_words\": unique_words,\n",
    "        \"most_frequent_word\": most_frequent_word\n",
    "    }\n",
    "\n",
    "    return result\n",
    "\n",
    "\n",
    "text = \"The quick brown fox jumps over the lazy dog the fox\"\n",
    "\n",
    "print(analyze_sentence(text))"
   ]
  },
