   "source": [
    "\"\"\"2. Given the string below, do the following and print each result:\n",
    "text = \"A man a plan a canal Panama\"\n",
    "a) Reverse the string without using slicing.\n",
    "b) Check if it is a palindrome, ignoring case and spaces.\n",
    "c) Replace every vowel with *.\n",
    "d) Count how many times each vowel appears.\"\"\";"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "id": "5cbf0b5a-3024-4524-af61-e4fc00089b60",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Reversed String : amanaP lanac a nalp a nam A\n",
      "Palindrome\n",
      "After Replacing Vowels : * m*n * pl*n * c*n*l P*n*m*\n",
      "Vowel Count : {'a': 10, 'e': 0, 'i': 0, 'o': 0, 'u': 0}\n"
     ]
    }
   ],
   "source": [
    "text = \"A man a plan a canal Panama\"\n",
    "\n",
    "# (a) Reverse String\n",
    "rev = \"\"\n",
    "\n",
    "for ch in text:\n",
    "    rev = ch + rev\n",
    "\n",
    "print(\"Reversed String :\", rev)\n",
    "\n",
    "# (b) Palindrome Check\n",
    "new_text = text.replace(\" \", \"\").lower()\n",
    "\n",
    "rev2 = \"\"\n",
    "\n",
    "for ch in new_text:\n",
    "    rev2 = ch + rev2\n",
    "\n",
    "if new_text == rev2:\n",
    "    print(\"Palindrome\")\n",
    "else:\n",
    "    print(\"Not Palindrome\")\n",
    "\n",
    "# (c) Replace Vowels with *\n",
    "result = \"\"\n",
    "\n",
    "for ch in text:\n",
    "    if ch.lower() in \"aeiou\":\n",
    "        result += \"*\"\n",
    "    else:\n",
    "        result += ch\n",
    "\n",
    "print(\"After Replacing Vowels :\", result)\n",
    "\n",
    "# (d) Count Vowels\n",
    "count = {\n",
    "    \"a\": 0,\n",
    "    \"e\": 0,\n",
    "    \"i\": 0,\n",
    "    \"o\": 0,\n",
    "    \"u\": 0\n",
    "}\n",
    "\n",
    "for ch in text.lower():\n",
    "    if ch in count:\n",
    "        count[ch] += 1\n",
    "\n",
    "print(\"Vowel Count :\", count)"
   ]
  },
